{
  "name": "@marineyachtradar/signalk-plugin",
  "version": "1.4.1",
  "description": "MaYaRa Radar - Connect SignalK to mayara-server",
  "main": "plugin/index.js",
  "signalk-plugin-enabled-by-default": true,
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" && eslint --fix 'src/**/*.ts' 'test/**/*.ts' && npm run format:other",
    "format:other": "prettier --write \"**/*.md\" \"*.{json,yml,yaml,mjs,js}\" \".github/**/*.{yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"**/*.md\" \"*.{json,yml,yaml,mjs,js}\" \".github/**/*.{yml,yaml}\"",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "build": "tsc && node build.js && webpack",
    "build:config": "webpack",
    "build:all": "npm run lint && npm run build && npm run test",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-instruments",
    "radar",
    "marine",
    "mayara",
    "signalk-plugin-configurator"
  ],
  "signalk": {
    "displayName": "MaYaRa Radar (Server)",
    "appIcon": "assets/mayara_logo.png",
    "webapp": {
      "name": "MaYaRa Radar",
      "description": "Marine radar display connected to mayara-server",
      "location": "/plugins/@marineyachtradar/signalk-plugin/"
    },
    "screenshots": [
      "./docs/screenshot/mayara_screenshot_1.png"
    ],
    "requires": [
      "signalk-container"
    ]
  },
  "files": [
    "plugin/**/*",
    "public/**/*",
    "docs/**/*"
  ],
  "engines": {
    "node": ">=22",
    "signalk": ">=2.24.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "http-proxy-middleware": "^3.0.5",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@signalk/server-api": "^2.24.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "babel-loader": "^10.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.5",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarineYachtRadar/mayara-server-signalk-plugin"
  },
  "author": "MarineYachtRadar Contributors",
  "license": "Apache-2.0"
}
