{
  "name": "@marineyachtradar/signalk-plugin",
  "version": "0.5.5",
  "description": "MaYaRa Radar - Connect SignalK to mayara-server",
  "main": "plugin/index.js",
  "scripts": {
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' && eslint --fix 'src/**/*.ts' 'test/**/*.ts'",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "build": "tsc && node build.js && webpack",
    "build:config": "webpack",
    "build:all": "npm run lint && npm run build && npm run test",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-instruments",
    "radar",
    "marine",
    "mayara",
    "signalk-plugin-configurator"
  ],
  "signalk": {
    "displayName": "MaYaRa Radar (Server)",
    "appIcon": "assets/mayara_logo.png",
    "webapp": {
      "name": "MaYaRa Radar",
      "description": "Marine radar display connected to mayara-server",
      "location": "/plugins/@marineyachtradar/signalk-plugin/"
    }
  },
  "files": [
    "plugin/**/*",
    "public/**/*"
  ],
  "engines": {
    "node": ">=20",
    "signalk": ">=2.24.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "ws": "^8.14.0"
  },
  "peerDependencies": {
    "signalk-container": ">=0.1.6"
  },
  "peerDependenciesMeta": {
    "signalk-container": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^9.0.0",
    "@signalk/server-api": "^2.24.0",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "babel-loader": "^10.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vitest": "^3.0.5",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarineYachtRadar/mayara-server-signalk-plugin"
  },
  "author": "MarineYachtRadar Contributors",
  "license": "Apache-2.0"
}
